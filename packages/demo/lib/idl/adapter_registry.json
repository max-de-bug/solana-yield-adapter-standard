  "types": [
    {
      "name": "AdapterEntry",
      "docs": [
        "On-chain record for a registered adapter.",
        "PDA seeded by `[ADAPTER_ENTRY_SEED, adapter_program_id]`."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "adapter_program_id",
            "docs": [
              "The adapter program's ID."
            ],
            "type": "pubkey"
          },
          {
            "name": "name",
            "docs": [
              "Human-readable adapter name."
            ],
            "type": "string"
          },
          {
            "name": "status",
            "docs": [
              "Current approval status."
            ],
            "type": {
              "defined": {
                "name": "AdapterStatus"
              }
            }
          },
          {
            "name": "underlying_mint",
            "docs": [
              "Mint of the underlying token this adapter handles."
            ],
            "type": "pubkey"
          },
          {
            "name": "metadata_uri",
            "docs": [
              "URI pointing to off-chain metadata (JSON)."
            ],
            "type": "string"
          },
          {
            "name": "vault_state_seed",
            "docs": [
              "The PDA seed bytes used by this adapter for its vault state account.",
              "Allows the dispatcher to validate vault state PDAs without hardcoding."
            ],
            "type": "bytes"
          },
          {
            "name": "vault_authority_seed",
            "docs": [
              "The PDA seed bytes used by this adapter for its vault authority account.",
              "Allows the dispatcher to validate vault authority PDAs generically."
            ],
            "type": "bytes"
          },
          {
            "name": "proposer",
            "docs": [
              "The account that proposed this adapter."
            ],
            "type": "pubkey"
          },
          {
            "name": "proposed_at",
            "docs": [
              "Timestamp when the adapter was proposed."
            ],
            "type": "i64"
          },
          {
            "name": "approved_at",
            "docs": [
              "Timestamp when the adapter was approved (0 if not approved)."
            ],
            "type": "i64"
          },
          {
            "name": "revoked_at",
            "docs": [
              "Timestamp when the adapter was revoked (0 if not revoked)."
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
              "Bump seed for the PDA."
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "AdapterStatus",
      "docs": [
        "The status of an adapter in the registry."
      ],
      "type": {
        "kind": "enum",
        "variants": [
          {
            "name": "Proposed"
          },
          {
            "name": "Approved"
          },
          {
            "name": "Revoked"
          }
        ]
      }
    },
    {
      "name": "RegistryState",
      "docs": [
        "Global registry configuration. Singleton PDA."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "The governance authority who can approve/revoke adapters and transfer governance."
            ],
            "type": "pubkey"
          },
          {
            "name": "guardian",
            "docs": [
              "Optional guardian with day-to-day approval/revoke powers (authority-only to set)."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "pending_authority",
            "docs": [
              "Pending governance authority for two-step transfer."
            ],
            "type": {
              "option": "pubkey"
            }
          },
          {
            "name": "total_proposed",
            "docs": [
              "Total number of adapters ever proposed."
            ],
            "type": "u64"
          },
          {
            "name": "total_approved",
            "docs": [
              "Total number of currently approved adapters."
            ],
            "type": "u64"
          },
          {
            "name": "bump",
            "docs": [
              "Bump seed for the PDA."
            ],
            "type": "u8"
          }
        ]
      }
    }
  ]
